{
  "name": "elysiajs-clean-architecture-event-management",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external elysia --external @elysiajs/swagger --external drizzle-orm --external postgres --external nanoid",
    "test": "bun test",
    "lint:error": "tsc --noEmit --pretty false | Select-String \"error\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/app/main/database/drizzle/seeds/seed.ts"
  },
  "dependencies": {
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@sinclair/typebox": "^0.34.11",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "nanoid": "^5.1.11",
    "nodemailer": "^8.0.7",
    "openapi-types": "^12.1.3",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@elysiajs/eden": "^1.4.9",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.2",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
