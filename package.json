{
  "name": "elysiajs-clean-architecture-event-management",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "test": "bun test",
    "lint:error": "tsc --noEmit --pretty false | Select-String \"error\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/infrastructure/seed.ts"
  },
  "dependencies": {
    "@elysiajs/swagger": "^1.3.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "nanoid": "^5.1.11",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
